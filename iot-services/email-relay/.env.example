# HTTP shared key used by the Feather when calling POST /send.
SHARED_KEY=replace-with-random-hex-key

# SMTP settings copied from OMV notification settings.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Fixed sender/recipient for monitoring emails.
MAIL_FROM=pi-nas@example.com
MAIL_TO=you@example.com

# Optional subject prefix.
SUBJECT_PREFIX=[Bouncy] 
